{
  "$schema": "https://www.schemastore.org/chrome-manifest.json",
  "manifest_version": 3,
  "name": "Page Translator",
  "version": "1.0.0",
  "description": "Page Translator",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "host_permissions": [
    "https://translate-pa.googleapis.com/*"
  ],
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage",
    "webNavigation"
  ]
}
